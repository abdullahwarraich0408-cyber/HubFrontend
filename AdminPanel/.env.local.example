# Production backend (use direct URL to avoid Node.js SSL errors when proxying in dev)
NEXT_PUBLIC_API_URL=https://medmarket.asrar.dev/api

# Only needed when NEXT_PUBLIC_API_URL=/api (Next.js rewrite proxy)
BACKEND_URL=https://medmarket.asrar.dev

# Stripe publishable key (sandbox)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
