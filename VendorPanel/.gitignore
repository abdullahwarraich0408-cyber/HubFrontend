# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# caches / tooling
.turbo
.swc
.eslintcache
.stylelintcache
.cache/
.parcel-cache/

# logs
*.log

# local uploads / temp (often large)
/uploads/
/tmp/
/temp/
/storage/
/data/
/public/uploads/
/public/storage/

# archives / installers (often large)
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.7z
*.rar
*.iso
*.dmg
*.exe
*.msi
*.apk
*.ipa

# large media / design files
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.psd
*.ai
*.sketch
*.fig
*.blend
*.fbx

# local databases
*.sqlite
*.sqlite3
*.db
